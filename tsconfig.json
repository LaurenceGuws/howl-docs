{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "lib": ["DOM", "ES2022"],
    "rootDir": "./ts",
    "outDir": "./build/js",
    "allowJs": true,
    "checkJs": false,
    "strict": true,
    "noEmitOnError": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true
  },
  "include": ["ts/**/*"]
}
